{
  "categories": [
    {
      "name": "RESOURCES",
      "_comment": "7 action types: add_gold, add_food, add_milk, add_orbs, give_item, give_blueprint, give_prop",
      "buttons": [
        {
          "label": "+1000 GOLD",
          "actions": [{"type": "add_gold", "amount": 1000}]
        },
        {
          "label": "INF FOOD",
          "actions": [{"type": "set_continuous", "effect": "inf_food"}],
          "toggle": true,
          "save_key": "inf_food_on"
        },
        {
          "label": "+50 FOOD",
          "actions": [{"type": "add_food", "amount": 50}]
        },
        {
          "label": "+10 MILK",
          "actions": [{"type": "add_milk", "amount": 10}]
        },
        {
          "label": "+5 ORBS",
          "actions": [{"type": "add_orbs", "amount": 5}]
        },
        {
          "label": "GET ITEM 12",
          "_comment": "give_item: item_id references game's item enum",
          "actions": [{"type": "give_item", "item_id": 12}]
        },
        {
          "label": "GET BLUEPRINT",
          "_comment": "give_blueprint: unlocks a prop blueprint by prop_id",
          "actions": [{"type": "give_blueprint", "prop_id": 3}]
        },
        {
          "label": "GET PROP",
          "_comment": "give_prop: adds a prop to inventory",
          "actions": [{"type": "give_prop", "prop_id": 5, "amount": 1}]
        }
      ]
    },

    {
      "name": "MONSTERS",
      "_comment": "5 action types: spawn_mon, set_troop_level, add_troop_exp, set_skill_level, set_troop_size",
      "buttons": [
        {
          "label": "SPAWN GOBLIN",
          "actions": [{"type": "spawn_mon", "mon_type": 0}]
        },
        {
          "label": "TROOP LVL 10",
          "actions": [{"type": "set_troop_level", "level": 10}]
        },
        {
          "label": "+500 TROOP EXP",
          "actions": [{"type": "add_troop_exp", "amount": 500}]
        },
        {
          "label": "SKILL LVL 5",
          "actions": [{"type": "set_skill_level", "level": 5}]
        },
        {
          "label": "TROOP SIZE 20",
          "actions": [{"type": "set_troop_size", "size": 20}]
        }
      ]
    },

    {
      "name": "UNITS",
      "_comment": "2 action types: create_unit, create_unit_cage",
      "buttons": [
        {
          "label": "ADD WITCH",
          "_comment": "create_unit: spawns a free unit of given class",
          "actions": [{"type": "create_unit", "class": "example_mod.WITCH"}]
        },
        {
          "label": "CAGE SIREN",
          "_comment": "create_unit_cage: spawns a caged unit of given class",
          "actions": [{"type": "create_unit_cage", "class": "example_mod.SIREN"}]
        }
      ]
    },

    {
      "name": "UNLOCKS",
      "_comment": "7 action types: unlock_boss, unlock_stage_next, unlock_breeds, unlock_cell, unlock_prop, unlock_raid, unlock_all_cells",
      "buttons": [
        {
          "label": "UNLOCK SIREN",
          "actions": [{"type": "unlock_boss", "class": "example_mod.SIREN"}]
        },
        {
          "label": "NEXT STAGE",
          "actions": [{"type": "unlock_stage_next"}]
        },
        {
          "label": "ALL BREEDS",
          "actions": [{"type": "unlock_breeds"}]
        },
        {
          "label": "UNLOCK HEX",
          "actions": [{"type": "unlock_cell", "h_type": "example_mod.HEX ROOM"}]
        },
        {
          "label": "UNLOCK PROP 2",
          "actions": [{"type": "unlock_prop", "prop_id": 2}]
        },
        {
          "label": "UNLOCK RAID 1",
          "actions": [{"type": "unlock_raid", "raid_id": 1}]
        },
        {
          "label": "ALL CELLS",
          "actions": [{"type": "unlock_all_cells"}]
        }
      ]
    },

    {
      "name": "ENVIRONMENT",
      "_comment": "3 action types: add_floor, set_day, add_day_time",
      "buttons": [
        {
          "label": "+1 FLOOR",
          "actions": [{"type": "add_floor", "amount": 1}]
        },
        {
          "label": "SET DAY 30",
          "actions": [{"type": "set_day", "day": 30}]
        },
        {
          "label": "+6H TIME",
          "actions": [{"type": "add_day_time", "hours": 6}]
        }
      ]
    },

    {
      "name": "SPEED & DISPLAY",
      "_comment": "3 action types: set_speed, swap_mouse, show_debug_overlay",
      "buttons": [
        {
          "label": "SPEED x3",
          "actions": [{"type": "set_speed", "value": 3}]
        },
        {
          "label": "SWAP MOUSE",
          "actions": [{"type": "swap_mouse"}]
        },
        {
          "label": "DEBUG OVERLAY",
          "actions": [{"type": "show_debug_overlay"}],
          "toggle": true
        }
      ]
    },

    {
      "name": "GENERIC",
      "_comment": "2 action types: set_val (16 allowlisted keys), set_var (1 allowlisted key)",
      "buttons": [
        {
          "label": "MAX MORALE",
          "_comment": "set_val: writes to allowlisted global keys",
          "actions": [{"type": "set_val", "key": "morale", "value": 100}]
        },
        {
          "label": "SET G_VAR",
          "_comment": "set_var: writes to allowlisted variable keys",
          "actions": [{"type": "set_var", "key": "debug_mode", "value": 1}]
        }
      ]
    },

    {
      "name": "RAID & SHOP",
      "_comment": "3 action types: reroll_shop, reroll_trade, reroll_encounters",
      "buttons": [
        {
          "label": "REROLL SHOP",
          "actions": [{"type": "reroll_shop"}]
        },
        {
          "label": "REROLL TRADE",
          "actions": [{"type": "reroll_trade"}]
        },
        {
          "label": "REROLL ENCOUNTERS",
          "actions": [{"type": "reroll_encounters"}]
        }
      ]
    },

    {
      "name": "STATE & META",
      "_comment": "6 action types: set_state, set_continuous, fire_event, fire_trigger, popup, play_sfx",
      "buttons": [
        {
          "label": "MOOD LOCK",
          "_comment": "set_continuous: registers a per-frame effect",
          "actions": [{"type": "set_continuous", "effect": "mood_lock"}],
          "toggle": true,
          "save_key": "mood_lock_on"
        },
        {
          "label": "RESET QUEST",
          "_comment": "set_state: writes to mod save_state field",
          "actions": [{"type": "set_state", "key": "quest_progress", "value": -1}]
        },
        {
          "label": "FIRE WITCH INTRO",
          "_comment": "fire_event: directly fires a named event from quests.json",
          "actions": [{"type": "fire_event", "event": "witch_intro"}]
        },
        {
          "label": "CHECK TRIGGERS",
          "_comment": "fire_trigger: re-evaluates all triggers for a given hook",
          "actions": [{"type": "fire_trigger", "hook": "post_raid_win"}]
        },
        {
          "label": "TEST POPUP",
          "_comment": "popup: shows a named popup from quests.json popups",
          "actions": [{"type": "popup", "popup": "witch_welcome"}],
          "guard": {"type": "state_equals", "key": "quest_progress", "value": -1}
        },
        {
          "label": "DING SFX",
          "_comment": "play_sfx: plays a sound effect",
          "actions": [{"type": "play_sfx", "sfx": "snd_coin"}]
        },
        {
          "label": "FULL RESET",
          "_comment": "=== Multiple actions in one button ===",
          "actions": [
            {"type": "set_state", "key": "quest_progress", "value": -1},
            {"type": "set_state", "key": "boss_state", "value": -1},
            {"type": "set_state", "key": "escape_count", "value": 0},
            {"type": "popup", "popup": "quest_done"}
          ]
        }
      ]
    }
  ],

  "keybinds": [
    {
      "_comment": "Single key with no modifier",
      "key": "F1",
      "modifier": "none",
      "actions": [{"type": "add_gold", "amount": 500}]
    },
    {
      "_comment": "Key with shift modifier",
      "key": "F2",
      "modifier": "shift",
      "actions": [{"type": "add_food", "amount": 100}]
    },
    {
      "_comment": "Key with ctrl modifier",
      "key": "F3",
      "modifier": "ctrl",
      "actions": [{"type": "add_milk", "amount": 10}]
    },
    {
      "_comment": "Key with alt modifier",
      "key": "F4",
      "modifier": "alt",
      "actions": [{"type": "add_orbs", "amount": 5}]
    },
    {
      "_comment": "Range key with {n} template substitution",
      "_modifiers": "Valid modifiers: none / shift / ctrl / alt",
      "key_type": "range",
      "key": "0-9",
      "modifier": "none",
      "actions": [{"type": "set_speed", "value": "{n}"}]
    }
  ]
}
